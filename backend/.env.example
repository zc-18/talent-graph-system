# ===== 智岗图谱 TalentGraph AI · 环境变量示例 =====
# 复制本文件为 backend/.env 并填入真实值（.env 已被 .gitignore 忽略，切勿提交）

# 数据库连接（MySQL）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=talent_graph

# DeepSeek 大模型（OpenAI 兼容）
DEEPSEEK_API_KEY=sk-your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tavily 联网检索（用于交叉验证/证据采集）
TAVILY_API_KEY=tvly-your_tavily_key

# Serper.dev Google 检索（第二独立来源，交叉验证）
SERPER_API_KEY=your_serper_key

# BGE 向量嵌入服务（语义匹配 / 去重 / RAG 接地，512 维）
EMBED_API_KEY=sk-your_embed_key
EMBED_BASE_URL=http://127.0.0.1:7001/v1
EMBED_MODEL=bge-small-zh-v1.5
EMBED_DIM=512

# 应用配置
APP_PORT=8200
CORS_ORIGINS=*
